# =============================================================================
# CONTROL PEDIDOS - VARIABLES DE ENTORNO PARA PRODUCCIÓN
# =============================================================================

# -----------------------------------------------------------------------------
# PLANETSCALE (MySQL Database)
# Obtener de: https://app.planetscale.com → your database → Credentials
# -----------------------------------------------------------------------------
DATABASE_URL="mysql://USERNAME:PASSWORD@HOST.planetscaledb.com/PROJECT_NAME?ssl={"rejectUnauthorized":true}&ssl-ca=/etc/ssl/certs/ca-certificate.crt"

# -----------------------------------------------------------------------------
# RAILWAY (Backend Server)
# -----------------------------------------------------------------------------
# Puerto del servidor (Railway asigna automáticamente via $PORT)
PORT=3001
NODE_ENV=production

# -----------------------------------------------------------------------------
# AUTENTICACIÓN Y SEGURIDAD
# -----------------------------------------------------------------------------
# Secret para cookies/jwt - generar con: openssl rand -base64 32
JWT_SECRET="TU_JWT_SECRET_AQUI_Mínimo_32_caracteres"

# -----------------------------------------------------------------------------
# OAUTH (Opcional - si usas autenticación social)
# -----------------------------------------------------------------------------
OAUTH_SERVER_URL="https://oauth.example.com"
# OWNER_OPEN_ID es tu ID de usuario admin para acceso total

# -----------------------------------------------------------------------------
# STORAGE (Forge API para uploads de imágenes)
# -----------------------------------------------------------------------------
# Estos valores los proporciona tu servicio de storage (Vercel Blob, AWS S3, etc.)
BUILT_IN_FORGE_API_URL="https://storage.example.com"
BUILT_IN_FORGE_API_KEY="TU_FORGE_API_KEY"

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=info
